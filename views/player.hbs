<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11.7.27/dist/sweetalert2.min.css">
<link rel="stylesheet" href="/css/players.css">

<div class="pl">
  <div class="pl__topbar">
    <div class="pl__topbar-links">
      <a href="/canciones" class="pl__link">
        <i class="fas fa-th-large"></i> Dashboard
      </a>
      <a href="/radio" class="pl__link pl__link--radio">
        <i class="fas fa-broadcast-tower"></i> Panel de Radio
      </a>
    </div>
    <form action="/logout" method="GET" style="margin:0">
      <button class="pl__logout-btn" type="submit">
        <i class="fas fa-sign-out-alt"></i> Cerrar sesión
      </button>
    </form>
  </div>

  <div class="pl__card">
    <div class="pl__header">
      <h1 class="pl__title"><i class="fas fa-list"></i> Playlists</h1>
      <button class="pl__create-btn" id="show-playlist">
        <i class="fas fa-plus"></i> Crear Playlist
      </button>
    </div>

    <div class="pl__list" id="playlists-list">
      <p class="pl__empty">Cargando playlists...</p>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11.7.27/dist/sweetalert2.all.min.js"></script>
<script defer src="/js/playList.js"></script>
