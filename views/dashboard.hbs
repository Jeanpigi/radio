<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11.7.27/dist/sweetalert2.min.css">
<link rel="stylesheet" href="/css/dashboard.css">
<link rel="stylesheet" href="/css/spiner.css">

<div id="loading-container" style="display:none;">
  <div class="spinner"></div>
  <p>Cargando los archivos</p>
</div>

<div class="dash">

  <div class="dash__topbar">
    <div class="dash__topbar-left">
      <a href="/player" class="dash__radio-link">
        <i class="fas fa-list"></i> Playlists
      </a>
      <a href="/radio" class="dash__radio-link">
        <i class="fas fa-broadcast-tower"></i> Panel de Radio
      </a>
    </div>
    <form action="/logout" method="GET" style="margin:0">
      <button class="dash__logout-btn" type="submit">
        <i class="fas fa-sign-out-alt"></i> Cerrar sesión
      </button>
    </form>
  </div>

  <div class="dash__grid">

    <div class="dash__card">
      <div class="dash__card-header">
        <h2><i class="fas fa-music"></i> Canciones <span class="dash__count">{{canciones.length}}</span></h2>
        <input class="dash__search" type="text" id="canciones-search" placeholder="Buscar...">
      </div>
      <div class="dash__list content__song" id="canciones-content">
        {{#each canciones}}
        <form action="/canciones/{{this.id}}" method="POST" class="delete-form">
          <div class="dash__item">
            <span class="dash__item-name">{{this.filename}}</span>
            <button class="dash__delete-btn" type="submit" onclick="confirmDelete(event)">
              <i class="fa fa-trash"></i>
            </button>
          </div>
        </form>
        {{/each}}
      </div>
    </div>

    <div class="dash__card dash__card--upload">
      <h2 class="dash__card-title"><i class="fas fa-upload"></i> Subir archivo</h2>
      <form class="dash__upload-form" action="/canciones" method="POST" enctype="multipart/form-data" id="uploadForm">
        <label class="dash__label">Tipo de archivo</label>
        <div class="custom-select">
          <select name="fileType" id="fileTypeSelect" onchange="changeFormAction(this.value)">
            <option value="" selected>Selecciona una opción</option>
            <option value="cancion">Canción</option>
            <option value="anuncio">Anuncio</option>
          </select>
        </div>

        <label class="dash__label">Archivo de audio</label>
        <input class="dash__file-input" type="file" name="archivo" accept="audio/*" id="filePath"
          oninput="enableUploadButton()" multiple />

        <div id="diaContainer" style="display:none;">
          <label class="dash__label">Día del anuncio</label>
          <div class="custom-select">
            <select name="dia" id="dia">
              <option value="T" selected>Todos</option>
              <option value="dom.">Domingo</option>
              <option value="lun.">Lunes</option>
              <option value="mar.">Martes</option>
              <option value="mié.">Miércoles</option>
              <option value="jue.">Jueves</option>
              <option value="vie.">Viernes</option>
              <option value="sáb.">Sábado</option>
            </select>
          </div>
        </div>

        <button class="dash__upload-btn" id="uploadButton" type="submit" disabled>
          <i class="fas fa-cloud-upload-alt"></i> Cargar
        </button>
      </form>
    </div>

    <div class="dash__card">
      <div class="dash__card-header">
        <h2><i class="fas fa-bullhorn"></i> Anuncios <span class="dash__count">{{anuncios.length}}</span></h2>
        <input class="dash__search" type="text" id="anuncios-search" placeholder="Buscar...">
      </div>
      <div class="dash__list content__song" id="anuncios-content">
        {{#each anuncios}}
        <form action="/audios/{{this.id}}" method="POST" class="delete-form">
          <div class="dash__item">
            <span class="dash__item-name">{{this.filename}}</span>
            <button class="dash__delete-btn" type="submit" onclick="confirmDelete(event)">
              <i class="fa fa-trash"></i>
            </button>
          </div>
        </form>
        {{/each}}
      </div>
    </div>

  </div>
</div>

<script defer src="/js/loadFile.js"></script>
<script defer src="/js/confirmDelete.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11.7.27/dist/sweetalert2.all.min.js"></script>
