<link rel="stylesheet" href="/css/radio.css">

<div class="radio__container">

  <div class="radio__topbar">
    <a href="/canciones" class="radio__back-link">
      <i class="fas fa-arrow-left"></i> Dashboard
    </a>
    <a href="/player" class="radio__back-link" style="margin-left:1.5rem">
      <i class="fas fa-list"></i> Playlists
    </a>
  </div>

  <div class="radio__panel">
    <h1 class="radio__title"><i class="fas fa-broadcast-tower"></i> Panel de Radio</h1>

    <div class="radio__now-playing">
      <span class="radio__label">En el aire:</span>
      <span id="now-playing-title" class="radio__song-name">— Sin reproducir —</span>
    </div>

    <div class="radio__monitor">
      <div class="radio__monitor-header">
        <span class="radio__label"><i class="fas fa-headphones"></i> Monitor:</span>
        <span id="mixer-live-badge" class="radio__mixer-live-badge" style="display:none">
          <i class="fas fa-circle"></i> Mixer al aire
        </span>
      </div>
      <audio id="admin-audio" controls style="width:100%; margin-top:0.5rem;"></audio>
    </div>

    <div class="radio__controls">
      <button id="btn-pause-resume" class="radio__btn radio__btn--primary" disabled>
        <i id="pause-resume-icon" class="fas fa-pause"></i>
        <span id="pause-resume-text">Pausar</span>
      </button>
      <button id="btn-next" class="radio__btn radio__btn--secondary">
        <i class="fas fa-forward"></i> Siguiente
      </button>
      <button id="btn-ad" class="radio__btn radio__btn--accent">
        <i class="fas fa-random"></i> Anuncio aleatorio
      </button>
    </div>

    <div class="radio__mixer">

      {{!-- Fila 1: Entrada de audio a transmitir (micrófono, mixer USB, etc.) --}}
      <div class="radio__mixer-row">
        <label class="radio__label" for="audio-input-select">
          <i class="fas fa-microphone"></i> Entrada a transmitir:
        </label>
        <select id="audio-input-select" class="radio__select" disabled>
          <option value="">— Selecciona una entrada —</option>
        </select>
        <button id="btn-detect-devices" class="radio__btn radio__btn--secondary" type="button">
          <i class="fas fa-sync-alt" id="detect-icon"></i> Detectar
        </button>
        <button id="btn-toggle-mixer" class="radio__btn radio__btn--mixer" type="button" disabled>
          <i class="fas fa-broadcast-tower"></i> Activar Mixer
        </button>
      </div>

      <p id="device-hint" class="radio__device-hint" style="display:none">
        Conecta el dispositivo y presiona <strong>Detectar</strong>.
      </p>

      {{!-- Fila 2: Volumen global --}}
      <div class="radio__mixer-row">
        <label class="radio__label" for="global-volume">
          <i class="fas fa-volume-up"></i> Volumen oyentes:
        </label>
        <input type="range" id="global-volume" class="radio__volume-slider" min="0" max="100" value="100">
        <span id="volume-value" class="radio__volume-value">100%</span>
      </div>

      {{!-- Fila 3: Ganancia del stream (visible solo con mixer activo) --}}
      <div class="radio__mixer-row" id="mixer-gain-row" style="display:none">
        <label class="radio__label" for="mixer-gain">
          <i class="fas fa-sliders-h"></i> Ganancia entrada:
        </label>
        <input type="range" id="mixer-gain" class="radio__volume-slider" min="0" max="200" value="100">
        <span id="mixer-gain-value" class="radio__volume-value">100%</span>
      </div>

      {{!-- Fila 4: Nivel de audio entrante (visible solo con mixer activo) --}}
      <div class="radio__mixer-row radio__mixer-vad" id="mixer-level-row" style="display:none">
        <label class="radio__label">
          <i class="fas fa-signal"></i> Nivel entrada:
        </label>
        <div class="vad-indicator" id="mixer-level-meter">
          <div class="vad-bar" id="mixer-level-bar"></div>
        </div>
      </div>

    </div>
  </div>

  <div class="radio__bottom-grid">

    <div class="radio__songs">
      <h2 class="radio__songs-title"><i class="fas fa-music"></i> Canciones</h2>
      {{#if canciones.length}}
      <div class="radio__songs-search-wrap">
        <input type="text" id="songs-search" class="radio__songs-search" placeholder="Buscar canción...">
      </div>
      <div class="radio__songs-list">
        {{#each canciones}}
        <div class="radio__song-item" data-path="{{this.path}}">
          <span class="radio__song-filename">{{this.filename}}</span>
          <button class="radio__btn radio__btn--play btn-play-song" data-path="{{this.path}}">
            <i class="fas fa-play"></i>
          </button>
        </div>
        {{/each}}
      </div>
      {{else}}
      <p class="radio__empty">No hay canciones. <a href="/canciones">Sube algunas desde el Dashboard.</a></p>
      {{/if}}
    </div>

    <div class="radio__playlists">
      <h2 class="radio__songs-title"><i class="fas fa-list"></i> Playlists</h2>
      <div id="playlists-container">
        <p class="radio__empty">Cargando playlists...</p>
      </div>
    </div>

    <div class="radio__anuncios">
      <h2 class="radio__songs-title"><i class="fas fa-bullhorn"></i> Anuncios</h2>
      {{#if anuncios.length}}
      <div class="radio__songs-list">
        {{#each anuncios}}
        <div class="radio__song-item radio__ad-item" data-path="{{this.path}}">
          <span class="radio__song-filename">{{this.filename}}</span>
          <button class="radio__btn radio__btn--play btn-play-ad" data-path="{{this.path}}">
            <i class="fas fa-play"></i>
          </button>
        </div>
        {{/each}}
      </div>
      {{else}}
      <p class="radio__empty">No hay anuncios. <a href="/canciones">Sube algunos desde el Dashboard.</a></p>
      {{/if}}
    </div>

  </div>

</div>

<script defer src="/js/radioAdmin.js"></script>
